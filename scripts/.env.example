# S3-compatible object storage credentials for backup sync.
# Copy this file to .env and fill in real values.
# Compatible with Hetzner Object Storage, Backblaze B2, AWS S3, Oracle Object Storage, MinIO, etc.

S3_ENDPOINT=https://nbg1.your-object-storage.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=s3://my-bucket/maps-backups
S3_REGION=eu-central-1
