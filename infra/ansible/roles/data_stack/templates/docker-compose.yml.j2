services:
  postgres:
    image: pgrouting/pgrouting:16-3.4-3.6
    container_name: maps-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: maps
      POSTGRES_PASSWORD: "{{ postgres_password }}"
      POSTGRES_DB: maps
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data

  memgraph:
    image: memgraph/memgraph-mage:latest
    container_name: maps-memgraph
    restart: unless-stopped
    ports:
      - "7687:7687"
    volumes:
      - mgdata:/var/lib/memgraph

volumes:
  pgdata:
  mgdata:
