{
  "name": "maps-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Graph Maps educational routing API — in-memory Dijkstra/A*, pgRouting and GraphHopper adapters, Redis cache-aside",
  "scripts": {
    "dev": "PORT=${PORT:-8080} tsx watch src/index.ts",
    "start": "PORT=${PORT:-8080} tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.0"
  }
}
